# PHPStan configuration for AgentReady.
#
# See docs/agdr/AgDR-0007-phpstan-static-analysis.md for the design rationale
# (level choice, scan scope, baseline policy, CI integration shape).
#
# Local loop: `composer phpstan`
# CI: the `phpstan` job in .github/workflows/ci.yml runs the same config.

includes:
    # WordPress core type stubs (WP_Query, WP_Post, hook signatures, common
    # globals). Provided by szepeviktor/phpstan-wordpress.
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    # NOTE: phpstan-baseline.neon was removed in #33. The baseline introduced
    # in #26 captured a single regex for `add_action`/`add_filter` "result
    # unused" — the refactor in #27 (which wrapped those calls in
    # `register_hooks()` method bodies) made the rule no longer fire, and
    # PHPStan 2.x's `reportUnmatchedIgnoredErrors: true` (default) flagged
    # the stale entry as drift. The codebase now passes level 5 cleanly with
    # zero baseline entries. If a future ticket re-introduces a third-party
    # stub gap, add `phpstan-baseline.neon` back here and document each entry
    # one-line per AgDR-0007's baseline policy.

parameters:
    # Level 5 — catches null deref, wrong arg types, dead code, missing returns
    # without drowning a small-team plugin in WP-core stub churn. WordPress/ai
    # runs level 8; we start lower and climb deliberately. See AgDR-0007.
    level: 5

    # PHP version range — matches the WPCTX_REQUIRES_PHP=7.4 floor and the
    # PHP-syntax matrix ceiling (8.3) in .github/workflows/ci.yml.
    phpVersion:
        min: 70400
        max: 80300

    paths:
        - includes/
        # Unit tests use a Provider seam + tests/Unit/wp-stubs.php and don't
        # load WP — safe to analyse. Integration tests are excluded (see
        # excludePaths) because they require wp-phpunit's type gymnastics.
        - tests/Unit/

    excludePaths:
        analyse:
            - vendor/
            # node_modules/ may not exist on every CI cell; mark optional.
            - node_modules/ (?)
            # Integration tests load wp-phpunit + WP core; analysing them
            # under PHPStan needs a separate bootstrap and produces more
            # noise than signal. Out of v0.1 scope per AgDR-0007.
            - tests/Integration/ (?)

    # Bootstrap files load plugin-global constants (WPCTX_FILE, WPCTX_VERSION,
    # WPCTX_REQUIRES_*) so references like \WPCTX_FILE resolve during analysis.
    # The constants() function in agent-ready.php defines them at runtime; we
    # mirror the definitions in a dedicated bootstrap file for PHPStan.
    bootstrapFiles:
        - tests/phpstan-bootstrap.php

    # WP-CLI class stubs — WP_CLI::add_command(), WP_CLI::error(), etc.
    # WP-CLI ships outside WordPress core; the szepeviktor stubs don't cover
    # it. Needed by includes/Cli/Markdown_Views_Command.php.
    scanFiles:
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php

    # Treat docblock types as "could be wrong" — WP-core docblocks are not
    # always tight. Matches WordPress/ai's posture.
    treatPhpDocTypesAsCertain: false

    # Baseline file (phpstan-baseline.neon) is included via the top-level
    # `includes:` directive above — that's the PHPStan 2.x idiom.
