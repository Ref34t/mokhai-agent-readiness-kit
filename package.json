{
	"name": "ai-readiness-kit",
	"private": true,
	"version": "0.2.0",
	"description": "AI Readiness for WordPress: context, policy, audit, analytics.",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/Ref34t/agentready.git"
	},
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js src",
		"format": "wp-scripts format src",
		"makepot": "wp i18n make-pot . languages/ai-readiness-kit.pot --domain=ai-readiness-kit --exclude=vendor,node_modules,build,tests",
		"wp-env": "wp-env",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:clean": "wp-env clean all",
		"test:integration": "wp-env run tests-cli --env-cwd=wp-content/plugins/ai-readiness-kit vendor/bin/phpunit"
	},
	"devDependencies": {
		"@wordpress/env": "^11.8.0",
		"@wordpress/scripts": "^32.4.0"
	},
	"overrides": {
		"minimatch": "^10.0.3",
		"serialize-javascript": "^7.0.5",
		"qs": "^6.15.2"
	}
}
