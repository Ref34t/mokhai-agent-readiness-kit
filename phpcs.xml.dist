<?xml version="1.0"?>
<ruleset name="AI Readiness Kit — layered WordPress + Slevomat">
	<description>
		Coding-standard ruleset for AI Readiness Kit. Layered per AgDR-0004:
		WordPress-VIP-Go (strictest) → WordPress-Core → WordPress-Extra
		→ PHPCompatibilityWP → Slevomat. Excluded sniffs are individually
		justified inline with the AgDR reference.
		Mirrors the WordPress/ai (the WP core team's AI plugin) phpcs.xml.dist.
	</description>

	<!-- ============================================================== -->
	<!-- Files to scan                                                  -->
	<!-- ============================================================== -->
	<file>.</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/languages/*</exclude-pattern>
	<!--
		.claude/ holds session state and local git worktrees (each worktree
		is a checkout of another branch). Scanning worktrees produces
		false-positive textdomain-mismatch and duplicate-class warnings
		against branches that are intentionally on older code. Not part of
		the runtime plugin and not part of the wp.org distribution ZIP.
	-->
	<exclude-pattern>*/.claude/*</exclude-pattern>

	<!--
		Tests + dev tools are NOT plugin runtime code. WP strict naming
		(`WPCTX_*` prefix on globals, escaping rules, runtime config bans)
		don't make sense for PHPUnit test files or autoload-verification
		scripts. Each directory keeps its own conventions (PHPUnit style;
		standard CLI script style) and is enforced by being unbroken in CI
		(php -l + phpunit). The Plugin Check Tool action in CI focuses on
		runtime plugin code, not tests/tools.
	-->
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/tools/*</exclude-pattern>

	<!-- ============================================================== -->
	<!-- Runtime config                                                 -->
	<!-- ============================================================== -->
	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg value="ps"/>
	<arg name="parallel" value="8"/>

	<!-- ============================================================== -->
	<!-- Layer 1 — WordPress-VIP-Go (strictest WP layer)                -->
	<!-- ============================================================== -->
	<rule ref="WordPress-VIP-Go">
		<!--
			VIP-Go forbids direct query construction; we don't write SQL at the
			scaffold level — exclude until #4/#9 introduce real query code,
			then re-enable per call site.
		-->
		<exclude name="WordPressVIPMinimum.Functions.RestrictedFunctions"/>

		<!--
			VIP-Go flags get_option for performance; AgentReady's options surface
			is tiny (agentready_settings + agentready_version). Re-evaluate when
			the option count grows.
		-->
		<exclude name="WordPressVIPMinimum.Functions.RestrictedFunctions.cache_get_option"/>
	</rule>

	<!-- ============================================================== -->
	<!-- Layer 2 — WordPress-Core                                        -->
	<!-- ============================================================== -->
	<rule ref="WordPress-Core"/>

	<!-- ============================================================== -->
	<!-- Layer 3 — WordPress-Extra (docblocks, file naming, etc.)        -->
	<!-- ============================================================== -->
	<rule ref="WordPress-Extra">
		<!--
			File-name rule expects class-foo.php; we use PSR-4 (Foo.php) per
			AgDR-0001 (#1's scaffold decision). Conflicts directly.
		-->
		<exclude name="WordPress.Files.FileName"/>
	</rule>

	<!-- ============================================================== -->
	<!-- Prefix lock — locked in #1 / AgDR-0004                          -->
	<!-- ============================================================== -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="WPCTX"/>
				<element value="wpctx"/>
				<element value="WPContext"/>
				<!--
					agentready_* is the prefix for option keys and the global
					agentready_has_ai_client() helper after the #18 rename.
					Internal namespace + constants (WPCTX_*, WPContext, wpctx_*)
					stay — they're not user-facing per wp.org policy.
				-->
				<element value="agentready"/>
			</property>
		</properties>
	</rule>

	<!-- ============================================================== -->
	<!-- Text-domain lock                                                -->
	<!-- ============================================================== -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="ai-readiness-kit"/>
			</property>
		</properties>
	</rule>

	<!-- ============================================================== -->
	<!-- Layer 4 — PHPCompatibilityWP (PHP 7.4+ × WP 7.0+)               -->
	<!-- ============================================================== -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- ============================================================== -->
	<!-- Layer 5 — Slevomat (strict types + namespace hygiene)           -->
	<!-- ============================================================== -->
	<rule ref="SlevomatCodingStandard.TypeHints.DeclareStrictTypes">
		<properties>
			<property name="declareOnFirstLine" value="false"/>
			<property name="linesCountBeforeDeclare" value="1"/>
			<property name="spacesCountAroundEqualsSign" value="0"/>
		</properties>
	</rule>

	<rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
		<properties>
			<property name="searchAnnotations" value="true"/>
		</properties>
	</rule>
</ruleset>
