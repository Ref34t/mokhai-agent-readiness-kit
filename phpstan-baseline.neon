# PHPStan baseline — third-party stub gaps only.
#
# Policy (per AgDR-0007): code-level issues are fixed in code; this file
# captures gaps in third-party type stubs that we cannot fix from this repo.
# Every entry MUST carry a one-line comment naming the upstream cause.
#
# Regenerate carefully via `vendor/bin/phpstan analyse --generate-baseline`,
# then re-annotate by hand — do not let auto-generation strip the comments.

parameters:
	ignoreErrors:
		# WP stub gap: php-stubs/wordpress-stubs declares `add_action()` (and
		# `add_filter`, `register_activation_hook`, `register_deactivation_hook`)
		# as `@return true`. PHPStan's function.resultUnused rule sees the
		# `true` return on a statement line and assumes the call is pointless,
		# but these functions register a hook as a side effect — the `true`
		# is informational, not the value the caller is after. Pattern matches
		# all four call sites in the scaffold today and any future bare-line
		# add_action / add_filter / register_*_hook in includes/.
		-
			message: '#^Call to function (add_action|add_filter|register_activation_hook|register_deactivation_hook)\(\) on a separate line has no effect\.$#'
			identifier: function.resultUnused
			path: includes/*
